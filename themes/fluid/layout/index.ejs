<%
var base = typeof url_for === 'function' ? url_for : function(p) { return p; };
var currentProjectUrl = 'https://sherlock0717.github.io/PsyLens/';
var githubUrl = 'https://github.com/sherlock0717';
var currentProjectCover = base('/img/project/psylens-cover-dark.png');
var heroPortrait = base('/img/site/home-portrait.png');
%>
<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>海澄｜项目展示主页</title>
  <meta name="description" content="海澄的项目展示主页，聚焦游戏研究、用户洞察、社区反馈分析与研究型工作流。">
  <link rel="stylesheet" href="<%= base('/css/custom.css') %>">

  <style>
    /* ===== 关键修复：抽屉相关样式直接内联，避免外部 css 不生效 ===== */
    .project-drawer {
      position: fixed;
      top: 0;
      right: 0;
      width: min(420px, 100vw);
      height: 100vh;
      z-index: 70;
      background: rgba(248, 251, 255, 0.96);
      backdrop-filter: blur(16px);
      border-left: 1px solid rgba(120, 146, 192, 0.12);
      box-shadow: -12px 0 36px rgba(45, 68, 112, 0.12);
      transform: translateX(102%);
      transition: transform .28s ease;
      display: none;
      flex-direction: column;
      padding: 24px 20px;
    }

    .project-drawer.is-open {
      transform: translateX(0);
    }

    .drawer-mask {
      position: fixed;
      inset: 0;
      background: rgba(20, 34, 60, 0.18);
      backdrop-filter: blur(2px);
      z-index: 60;
      opacity: 0;
      pointer-events: none;
      transition: opacity .24s ease;
      display: none;
    }

    .drawer-mask.is-open {
      opacity: 1;
      pointer-events: auto;
    }

    .drawer-head {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 16px;
      padding-bottom: 18px;
      border-bottom: 1px solid rgba(120, 146, 192, 0.12);
    }

    .drawer-kicker {
      margin: 0 0 8px;
      color: #7e8ba6;
      font-size: .8rem;
      letter-spacing: .16em;
      text-transform: uppercase;
    }

    .drawer-head h2 {
      margin: 0;
      font-size: 1.5rem;
      color: #203457;
    }

    .drawer-close {
      appearance: none;
      border: 0;
      background: rgba(255,255,255,0.72);
      width: 38px;
      height: 38px;
      border-radius: 999px;
      font-size: 1.6rem;
      line-height: 1;
      cursor: pointer;
      color: #44536d;
    }

    .drawer-list {
      display: grid;
      gap: 16px;
      margin-top: 20px;
      overflow: auto;
      padding-right: 2px;
    }

    .drawer-card {
      display: grid;
      grid-template-columns: 112px 1fr;
      gap: 14px;
      padding: 12px;
      border-radius: 18px;
      background: rgba(255,255,255,0.86);
      border: 1px solid rgba(120, 146, 192, 0.12);
      cursor: pointer;
      transition: transform .22s ease, box-shadow .22s ease;
    }

    .drawer-card:hover {
      transform: translateY(-2px);
      box-shadow: 0 14px 28px rgba(50, 78, 132, 0.12);
    }

    .drawer-cover {
      border-radius: 12px;
      overflow: hidden;
      background: #dfe9fb;
    }

    .drawer-cover img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .drawer-body h3 {
      margin: 2px 0 8px;
      font-size: 1.08rem;
      color: #203457;
    }

    .drawer-body p {
      margin: 0;
      color: #627089;
      line-height: 1.65;
      font-size: .92rem;
    }

    .drawer-link {
      display: inline-flex;
      margin-top: 12px;
      font-weight: 700;
      color: #2d72ea;
    }

    .nav-project-trigger {
      position: relative;
      transition: color .2s ease;
      background: none;
      border: 0;
      padding: 0;
      font: inherit;
      color: inherit;
      cursor: pointer;
    }

    .nav-project-trigger::after {
      content: "";
      position: absolute;
      left: 0;
      bottom: -6px;
      width: 100%;
      height: 2px;
      border-radius: 999px;
      background: linear-gradient(90deg, #5b86f7, #9bb8ff);
      transform: scaleX(0);
      transform-origin: left;
      transition: transform .24s ease;
    }

    .nav-project-trigger:hover {
      color: var(--text, #10213a);
    }

    .nav-project-trigger:hover::after {
      transform: scaleX(1);
    }

    .gate-enter {
      text-decoration: none;
    }

    @media (max-width: 760px) {
      .project-drawer {
        width: 100vw;
        padding: 18px 16px;
      }

      .drawer-card {
        grid-template-columns: 96px 1fr;
      }
    }
  </style>
</head>
<body class="portfolio-home home-page">
  <div class="gate-overlay" id="gateOverlay" aria-hidden="false">
    <div class="gate-grid"></div>
    <div class="gate-inner">
      <p class="gate-kicker">HAICHENG PORTFOLIO</p>
      <h1 class="gate-title">海的那边…</h1>
      <p class="gate-text">点击、滚轮下滑或上滑进入</p>
      <a class="gate-enter" href="#homeContent" id="gateEnter">进入主页</a>
      <div class="gate-indicator" aria-hidden="true"><span></span></div>
    </div>
  </div>

  <aside class="project-drawer" id="projectDrawer" aria-hidden="true" style="display:none;">
    <div class="drawer-head">
      <div>
        <p class="drawer-kicker">PROJECTS</p>
        <h2>项目预览</h2>
      </div>
      <button class="drawer-close" id="drawerClose" type="button" aria-label="关闭">×</button>
    </div>

    <div class="drawer-list">
      <article class="drawer-card click-card" data-url="<%= currentProjectUrl %>">
        <div class="drawer-cover">
          <img src="<%= currentProjectCover %>" alt="PsyLens">
        </div>
        <div class="drawer-body">
          <h3>PsyLens</h3>
          <p>多平台游戏社区反馈洞察工作流</p>
          <span class="drawer-link">查看项目</span>
        </div>
      </article>
    </div>
  </aside>

  <div class="drawer-mask" id="drawerMask" aria-hidden="true" style="display:none;"></div>

  <header class="topbar">
    <div class="shell topbar-inner">
      <nav class="navlinks">
        <a href="<%= base('/') %>">首页</a>
        <button class="nav-project-trigger" id="projectTrigger" type="button">项目</button>
      </nav>
    </div>
  </header>

  <main id="homeContent">
    <section class="hero-intro shell reveal">
      <div class="hero-layout">
        <div class="hero-portrait-column">
          <div class="hero-portrait-card">
            <img class="hero-portrait" src="<%= heroPortrait %>" alt="海澄个人形象图">
          </div>
          <p class="hero-quote">I think therefore I am</p>
        </div>

        <div class="hero-copy">
          <p class="eyebrow">GAME RESEARCH · USER INSIGHTS · WORKFLOW DESIGN</p>
          <h1 class="hero-title">游戏研究｜用户洞察｜研究型工作流</h1>
                    <p class="hero-desc hero-desc-kaiti">
            你好！我是海澄<br>
            应用心理学背景，正在关注用户研究与自动化工作流开发。<br>
            这里会陈列我研究的课题与项目。当前已公开完整案例 1 项，后续会继续补充新的研究案例、开发项目与方法整理。
          </p>
          <div class="hero-actions">
            <a class="pill-button pill-primary" href="<%= githubUrl %>" target="_blank" rel="noopener noreferrer">查看开发中的项目</a>
          </div>
        </div>
      </div>
    </section>

    <section class="shell reveal">
      <div class="section-head">
        <p class="section-kicker">PROJECTS</p>
        <h2>项目预览</h2>
        <p>当前先展示已公开项目，后续项目会在这里继续补充。</p>
      </div>

      <article class="featured-card click-card" data-url="<%= currentProjectUrl %>">
        <a class="featured-cover" href="<%= currentProjectUrl %>" target="_blank" rel="noopener noreferrer">
          <img src="<%= currentProjectCover %>" alt="PsyLens">
        </a>
        <div class="featured-content">
          <div class="meta-row">
            <span class="meta-date">2026-04-05</span>
          </div>
          <h3><a href="<%= currentProjectUrl %>" target="_blank" rel="noopener noreferrer">PsyLens｜多平台游戏社区反馈洞察工作流</a></h3>
          <p class="card-desc">后续会逐步加入新的项目页。</p>
          <div class="tag-row">
            <span>PsyLens</span>
            <span>游戏研究</span>
            <span>社区反馈分析</span>
          </div>
          <a class="text-link" href="<%= currentProjectUrl %>" target="_blank" rel="noopener noreferrer">查看项目</a>
        </div>
      </article>

      <div class="card-grid card-grid-3">
                                <article class="project-card is-disabled">
          <div class="project-cover cover-soft">
            <img src="<%= base('/img/project/more-projects-cover.png') %>" alt="更多项目持续补充中">
          </div>
          <div class="project-body">
            <h3>更多项目持续补充中</h3>
            <p class="card-desc">
              后续会逐步加入新的项目页。
            </p>
            <div class="tag-row">
              <span>持续更新</span>
              <span>建设中</span>
            </div>
          </div>
        </article>
      </div>
    </section>

    <section class="shell about-strip reveal">
      <div class="about-copy">
        <p class="section-kicker">UPDATE</p>
        <h2>敬请期待更新</h2>
        <p>
          这个首页会持续补充新的项目入口与预览内容。随着后续项目逐步公开，这里会形成更完整的项目展示结构，
          欢迎之后再回来看看。
        </p>
      </div>
    </section>
  </main>

  <script>
  (function () {
    var gate = document.getElementById('gateOverlay');
    var enterBtn = document.getElementById('gateEnter');
    var body = document.body;
    var touchStartY = null;
    var params = new URLSearchParams(window.location.search);
    var forceGate = params.get('gate') === '1';
    var sessionKey = 'haicheng-home-inline-v3';

    var drawer = document.getElementById('projectDrawer');
    var drawerMask = document.getElementById('drawerMask');
    var drawerTrigger = document.getElementById('projectTrigger');
    var drawerClose = document.getElementById('drawerClose');

    function initReveal() {
      var items = document.querySelectorAll('.reveal');
      if (!items.length || !('IntersectionObserver' in window)) {
        items.forEach(function (item) { item.classList.add('is-visible'); });
        return;
      }

      var observer = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      }, {
        threshold: 0.14,
        rootMargin: '0px 0px -40px 0px'
      });

      items.forEach(function (item, index) {
        item.style.transitionDelay = Math.min(index * 0.05, 0.24) + 's';
        observer.observe(item);
      });
    }

    function initClickableCards() {
      document.querySelectorAll('.click-card[data-url]').forEach(function (card) {
        var url = card.getAttribute('data-url');
        if (!url || url === '#') return;

        card.setAttribute('tabindex', '0');

        card.addEventListener('click', function (e) {
          if (e.target.closest('a, button')) return;
          window.location.href = url;
        });

        card.addEventListener('keydown', function (e) {
          if (e.key === 'Enter' || e.key === ' ') {
            e.preventDefault();
            window.location.href = url;
          }
        });
      });
    }

    function hideGateInstantly() {
      if (!gate) return;
      gate.classList.add('is-hidden');
      gate.setAttribute('aria-hidden', 'true');
      body.classList.remove('gate-locked');
    }

    function dismissGate() {
      if (!gate) return;
      gate.classList.add('is-leaving');
      gate.setAttribute('aria-hidden', 'true');
      body.classList.remove('gate-locked');
      try { sessionStorage.setItem(sessionKey, '1'); } catch (e) {}
      setTimeout(function () {
        gate.classList.add('is-hidden');
      }, 500);
    }

    function openDrawer() {
      if (!drawer || !drawerMask) return;
      drawer.style.display = 'flex';
      drawerMask.style.display = 'block';
      requestAnimationFrame(function () {
        drawer.classList.add('is-open');
        drawerMask.classList.add('is-open');
      });
      drawer.setAttribute('aria-hidden', 'false');
      drawerMask.setAttribute('aria-hidden', 'false');
      body.classList.add('drawer-open');
    }

    function closeDrawer() {
      if (!drawer || !drawerMask) return;
      drawer.classList.remove('is-open');
      drawerMask.classList.remove('is-open');
      drawer.setAttribute('aria-hidden', 'true');
      drawerMask.setAttribute('aria-hidden', 'true');
      body.classList.remove('drawer-open');
      setTimeout(function () {
        drawer.style.display = 'none';
        drawerMask.style.display = 'none';
      }, 260);
    }

    initReveal();
    initClickableCards();

    if (drawerTrigger) {
      drawerTrigger.addEventListener('click', function () {
        if (drawer && drawer.classList.contains('is-open')) {
          closeDrawer();
        } else {
          openDrawer();
        }
      });
    }

    if (drawerClose) drawerClose.addEventListener('click', closeDrawer);
    if (drawerMask) drawerMask.addEventListener('click', closeDrawer);

    window.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') closeDrawer();
    });

    if (!gate) return;

    try {
      if (!forceGate && sessionStorage.getItem(sessionKey) === '1') {
        hideGateInstantly();
        return;
      }
    } catch (e) {}

    body.classList.add('gate-locked');

    if (enterBtn) {
      enterBtn.addEventListener('click', function (e) {
        e.preventDefault();
        dismissGate();
        var home = document.getElementById('homeContent');
        if (home) home.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    }

    gate.addEventListener('click', function (e) {
      if (e.target === gate) dismissGate();
    });

    window.addEventListener('wheel', function (e) {
      if (!gate || gate.classList.contains('is-hidden')) return;
      if (e.deltaY > 8) dismissGate();
    }, { passive: true });

    window.addEventListener('keydown', function (e) {
      if (!gate || gate.classList.contains('is-hidden')) return;
      if (e.key === 'Enter' || e.key === ' ' || e.key === 'ArrowDown') {
        dismissGate();
      }
    });

    window.addEventListener('touchstart', function (e) {
      if (!gate || gate.classList.contains('is-hidden')) return;
      if (!e.touches || !e.touches.length) return;
      touchStartY = e.touches[0].clientY;
    }, { passive: true });

    window.addEventListener('touchend', function (e) {
      if (!gate || gate.classList.contains('is-hidden')) return;
      if (touchStartY === null) return;
      if (!e.changedTouches || !e.changedTouches.length) return;

      var endY = e.changedTouches[0].clientY;
      if (touchStartY - endY > 48) dismissGate();
      touchStartY = null;
    }, { passive: true });
  })();
  </script>
</body>
</html>




